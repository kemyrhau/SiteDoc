model FtdNotaComment {
  id          String   @id @default(cuid())
  specPostId  String?  @map("spec_post_id")
  periodId    String?  @map("period_id")
  commentText String   @map("comment_text")
  createdAt   DateTime @default(now()) @map("created_at")

  specPost FtdSpecPost?   @relation(fields: [specPostId], references: [id], onDelete: Cascade)
  period   FtdNotaPeriod? @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([specPostId])
  @@index([periodId])
  @@map("ftd_nota_comments")
}

// ── PSI (Prosjektspesifikk Sikkerhetsinstruks) ──────────────────────

model Psi {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  byggeplassId String?  @map("byggeplass_id")  // null = gjelder hele prosjektet
  templateId   String   @map("template_id")
  version      Int      @default(1)
  active       Boolean  @default(true)
  languages    String[] @default([])            // Språk PSI er oversatt til (f.eks. ["en", "lt", "pl"])
  guestMessage String?  @map("guest_message")  // Admin-beskjed til gjester uten HMS-kort
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byggeplass Byggeplass?    @relation(fields: [byggeplassId], references: [id], onDelete: SetNull)
  template   ReportTemplate @relation(fields: [templateId], references: [id])
  signaturer PsiSignatur[]

  @@unique([projectId, byggeplassId])  // Én PSI per prosjekt+byggeplass
  @@index([byggeplassId])
  @@map("psi")
}

model PsiSignatur {
  id           String    @id @default(uuid())
  psiId        String    @map("psi_id")
  psiVersion   Int       @map("psi_version")

  // Innlogget bruker ELLER gjest
  userId       String?   @map("user_id")
  guestName    String?   @map("guest_name")
  guestCompany String?   @map("guest_company")
  guestPhone   String?   @map("guest_phone")

  hmsKortNr       String?   @map("hms_kort_nr")       // HMS-kortnummer (NO xxxxxxxxx)
  harIkkeHmsKort  Boolean   @default(false) @map("har_ikke_hms_kort")  // Gjest: har ikke HMS-kort

  data            Json      @default("{}")
  signatureData   String?   @map("signature_data")
  language        String    @default("nb")
  progress        Int       @default(0)
  completedAt     DateTime? @map("completed_at")
  startedAt       DateTime  @default(now()) @map("started_at")

  psi  Psi   @relation(fields: [psiId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([psiId, userId])
  @@index([psiId])
  @@map("psi_signaturer")
}

// ---------------------------------------------------------------------------
// Sjekklistebibliotek — globalt arkiv med NS 3420-maler
// ---------------------------------------------------------------------------

model BibliotekStandard {
  id        String              @id @default(cuid())
  kode      String              @unique
  navn      String
  aktiv     Boolean             @default(true)
  sortering Int                 @default(0)
  opprettet DateTime            @default(now()) @map("opprettet")
  kapitler  BibliotekKapittel[]

  @@map("bibliotek_standarder")
}

model BibliotekKapittel {
  id         String            @id @default(cuid())
  kode       String
  navn       String
  sortering  Int
  standardId String            @map("standard_id")
  standard   BibliotekStandard @relation(fields: [standardId], references: [id], onDelete: Cascade)
  maler      BibliotekMal[]

  @@index([standardId])
  @@map("bibliotek_kapitler")
}

model BibliotekMal {
  id             String                  @id @default(cuid())
  kapittelId     String                  @map("kapittel_id")
  kapittel       BibliotekKapittel       @relation(fields: [kapittelId], references: [id], onDelete: Cascade)
  navn           String
  referanse      String
  beskrivelse    String?
  versjon        String                  @default("1.0")
  aktiv          Boolean                 @default(true)
  prioritet      Int                     @default(1)   // 1=grunnpakke, 2=utvidet, 3=spesialist
  // Per fase-0-beslutninger.md § E steg 8 — lukker P-KRITISK-3 (bibliotek.ts hardkodet category/domain)
  kategori       String                  @default("sjekkliste") // "oppgave" | "sjekkliste" — matcher ReportTemplate.category
  domene         String                  @default("kvalitet")   // "bygg" | "hms" | "kvalitet" — sentralbibliotek er NS 3420-K
  kobletTilModul String?                 @map("koblet_til_modul") // Slug til prosjektmodul (f.eks. "okonomi", "psi")
  verifisert     Boolean                 @default(false)         // True når malen er verifisert mot kilde-norm
  opprettet      DateTime                @default(now()) @map("opprettet")
  malInnhold     Json                    @map("mal_innhold")
  prosjektValg   ProsjektBibliotekValg[]

  @@index([kapittelId])
  @@map("bibliotek_maler")
}

model ProsjektBibliotekValg {
  id              String       @id @default(cuid())
  prosjektId      String       @map("prosjekt_id")
  bibliotekMalId  String       @map("bibliotek_mal_id")
  bibliotekMal    BibliotekMal @relation(fields: [bibliotekMalId], references: [id], onDelete: Cascade)
  sjekklisteMalId String?      @map("sjekkliste_mal_id")
  aktivertAv      String       @map("aktivert_av")
  aktivertDato    DateTime     @default(now()) @map("aktivert_dato")

  @@unique([prosjektId, bibliotekMalId])
  @@index([prosjektId])
  @@map("prosjekt_bibliotek_valg")
}

// ---------------------------------------------------------------------------
// Kontrollplan — stedsbasert kvalitetskontroll (SAK10 §14-7)
// ---------------------------------------------------------------------------

model Kontrollplan {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  byggeplassId  String    @map("byggeplass_id")
  navn          String    // "Kontrollplan — Blokk A"
  status        String    @default("utkast") // utkast | aktiv | godkjent | arkivert
  godkjentDato  DateTime? @map("godkjent_dato")
  godkjentAvId  String?   @map("godkjent_av_id")
  opprettet     DateTime  @default(now())
  oppdatert     DateTime  @updatedAt

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byggeplass Byggeplass @relation(fields: [byggeplassId], references: [id], onDelete: Cascade)
  godkjentAv User?      @relation("KontrollplanGodkjenner", fields: [godkjentAvId], references: [id], onDelete: SetNull)
  milepeler  Milepel[]
  punkter    KontrollplanPunkt[]

  @@unique([projectId, byggeplassId])
  @@index([projectId])
  @@map("kontrollplaner")
}

model Milepel {
  id             String @id @default(cuid())
  kontrollplanId String @map("kontrollplan_id")
  navn           String // "2. etasje bad ferdig"
  maalUke        Int    @map("maal_uke")  // Ukenummer (1-53)
  maalAar        Int    @map("maal_aar")  // År (2026)
  sortering      Int    @default(0)

  kontrollplan Kontrollplan        @relation(fields: [kontrollplanId], references: [id], onDelete: Cascade)
  punkter      KontrollplanPunkt[]

  @@index([kontrollplanId])
  @@map("milepeler")
}

model KontrollplanPunkt {
  id              String    @id @default(cuid())
  kontrollplanId  String    @map("kontrollplan_id")
  milepelId       String?   @map("milepel_id")
  omradeId        String?   @map("omrade_id")          // Nullable — lite prosjekt trenger ikke områder
  sjekklisteMalId String    @map("sjekkliste_mal_id")
  faggruppeId     String    @map("faggruppe_id")
  fristUke        Int?      @map("frist_uke")           // Ukenummer (1-53)
  fristAar        Int?      @map("frist_aar")           // År (2026)
  varselUkerFor   Int       @default(1) @map("varsel_uker_for")
  status          String    @default("planlagt")        // planlagt | pagar | utfort | godkjent
  sjekklisteId    String?   @unique @map("sjekkliste_id")
  avhengerAvId    String?   @map("avhenger_av_id")
  opprettet       DateTime  @default(now())

  kontrollplan  Kontrollplan      @relation(fields: [kontrollplanId], references: [id], onDelete: Cascade)
  milepel       Milepel?          @relation(fields: [milepelId], references: [id], onDelete: SetNull)
  omrade        Omrade?           @relation(fields: [omradeId], references: [id], onDelete: SetNull)
  sjekklisteMal ReportTemplate    @relation(fields: [sjekklisteMalId], references: [id])
  faggruppe     Faggruppe         @relation(fields: [faggruppeId], references: [id])
  sjekkliste    Checklist?        @relation(fields: [sjekklisteId], references: [id], onDelete: SetNull)
  avhengerAv    KontrollplanPunkt?  @relation("PunktAvhengighet", fields: [avhengerAvId], references: [id], onDelete: SetNull)
  blokkerer     KontrollplanPunkt[] @relation("PunktAvhengighet")
  historikk     KontrollplanHistorikk[]

  @@unique([kontrollplanId, omradeId, sjekklisteMalId])
  @@index([kontrollplanId])
  @@index([milepelId])
  @@index([omradeId])
  @@index([faggruppeId])
  @@index([status])
  @@index([fristUke, fristAar])
  @@map("kontrollplan_punkter")
}

model KontrollplanHistorikk {
  id        String   @id @default(cuid())
  punktId   String   @map("punkt_id")
  brukerId  String   @map("bruker_id")
  handling  String   // opprettet | startet | utfort | godkjent | avvist | endret
  kommentar String?
  tidspunkt DateTime @default(now())

  punkt  KontrollplanPunkt @relation(fields: [punktId], references: [id], onDelete: Cascade)
  bruker User              @relation(fields: [brukerId], references: [id])

  @@index([punktId])
  @@map("kontrollplan_historikk")
}

// ---------------------------------------------------------------------------
// Activity — sentral audit-tabell (action-events, ikke felt-nivå-diff)
// Per fase-0-beslutninger.md § A.3 + § E steg 1.
// Bevisst INGEN @relation på actorUserId/organizationId/projectId — audit-spor
// må overleve user-anonymisering (A.12) og prosjekt-/organisasjons-sletting.
// ---------------------------------------------------------------------------

model Activity {
  id                String   @id @default(cuid())
  actorUserId       String?  @map("actor_user_id")
  actorNavnSnapshot String?  @map("actor_navn_snapshot")
  organizationId    String?  @map("organization_id")
  projectId         String?  @map("project_id")
  targetType        String   @map("target_type")
  targetId          String   @map("target_id")
  action            String
  payload           Json?
  ipAddress         String?  @map("ip_address")
  userAgent         String?  @map("user_agent")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  retainedUntil  DateTime? @map("retained_until")
  anonymizedAt   DateTime? @map("anonymized_at")

  @@index([organizationId, createdAt])
  @@index([projectId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
  @@index([targetType, action, createdAt])
  @@map("activity_log")
}

// ---------------------------------------------------------------------------
// ExternalCostObject — felles kostnadsbærer-referanse (Underprosjekt i UI)
// Per fase-0-beslutninger.md § A.1 + § E steg 11.
// Refereres av Timer-modul (Fase 3) og Godkjenning-dokumentflyt (E.12).
// UI-term «Underprosjekt» (anleggsbransjens etablerte begrep, A.Markussen/SmartDok).
// Variabelnavn i kode: externalCostObjectId, eco, externalCostObject.
//
// Audit-felter (per A.3-mønster): opprettetAvUserId og lukketAvUserId
// er bevisst UTEN @relation — bevarer audit-spor ved User-sletting.
// ---------------------------------------------------------------------------

model ExternalCostObject {
  id                    String   @id @default(uuid())
  organizationId        String   @map("organization_id")
  projectId             String   @map("project_id")

  proAdmId              String   @map("proadm_id")              // UI-referanse fra ProAdm
  proAdmIdAtImport      String?  @map("proadm_id_at_import")    // Snapshot ved import (per A.22)
  proAdmType            String?  @map("proadm_type")             // ProAdm-typebegrep (varsel/endring/tilleggsarbeid/regningsarbeid m.fl.). Fri streng — utvides dynamisk når nye typer dukker opp. Kan kobles til Godkjenning-flytmal i fremtidig runde.

  kortNavn              String   @map("kort_navn")
  kilde                 String                                   // "proadm_import" | "manuell" | "felt_opprettet"
  kildeId               String?  @map("kilde_id")

  status                String   @default("aktiv")              // "aktiv" | "lukket"
  timerregistreringApen Boolean  @default(true) @map("timerregistrering_apen") // per B.1

  // Audit på lukking (per C.6) — String UTEN @relation per A.3-mønster
  lukketVed             DateTime? @map("lukket_ved")
  lukketAvUserId        String?   @map("lukket_av_user_id")
  lukketGrunn           String?   @map("lukket_grunn")

  // Soft-delete (per C.7)
  slettetVed            DateTime? @map("slettet_ved")

  // String UTEN @relation per A.3-mønster (audit-spor overlever User-sletting)
  opprettetAvUserId     String   @map("opprettet_av_user_id")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  godkjenninger Godkjenning[]

  @@unique([organizationId, proAdmId])
  @@index([projectId, status])
  @@index([slettetVed])
  @@map("external_cost_objects")
}

// ---------------------------------------------------------------------------
// OrganizationRole — granulære firma-roller (per A.25)
// Per fase-0-beslutninger.md § E steg 14 + A.25.
// Egen tabell (ikke utvidelse av User.role-enum) for skalerbarhet.
// Første rolle: "hms_ansvarlig" (per A.27 — automatisk lese-tilgang til
// HMS-rapporter på tvers av firmaets prosjekter).
// Tildeles av firma-admin via organisasjon.tildelOrgRolle / fjernOrgRolle.
// ---------------------------------------------------------------------------

model OrganizationRole {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           String   // "hms_ansvarlig" — utvides etter behov
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, role])
  @@index([organizationId, role])
  @@map("organization_roles")
}

// ---------------------------------------------------------------------------
// Avdeling — firma-intern organisatorisk inndeling (Fase 0.5 § 1)
// Per fase-0-beslutninger.md § C.11 + byggeplass-strategi.md § Avdeling.
//
// Skiller seg fra Byggeplass:
// - Avdeling = organisatorisk inndeling av firma (Tromsø, Narvik, Transport)
// - Byggeplass = fysisk lokasjon innenfor et prosjekt
//
// «Uten avdeling» (User.avdelingId = NULL) er gyldig permanent tilstand.
// ---------------------------------------------------------------------------

model Avdeling {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  kode            String?                              // intern kode, kan være null
  navn            String
  aktiv           Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  brukere      User[]

  @@unique([organizationId, navn])
  @@index([organizationId, aktiv])
  @@map("avdelinger")
}

// ---------------------------------------------------------------------------
// Kompetansetype + AnsattKompetanse — kompetansematrise (Fase 0.5 § 2)
// Per fase-0-beslutninger.md § A.28 + § C.14.
// To-tabell-struktur verifisert mot SmartDok 2026-04-29
// (Kompetanseoversikt + Kompetansetyper-fane + Brukernes kompetanser).
//
// Kategori-katalog: 7 SmartDok-bekreftede kategorier seedet i
// packages/shared/src/types/index.ts (KOMPETANSE_KATEGORIER).
//
// RBAC: konfigureres per firma via OrganizationSetting.kompetanseRegistreringTilgang
// (firma_admin | bruker_egen | alle, default firma_admin).
//
// Vedlegg: Json-array på AnsattKompetanse (samme mønster som
// ServiceRecord.vedlegg i db-maskin). Ingen separat vedlegg-tabell.
//
// Cascade-policy:
// - Kompetansetype → Organization: Cascade
// - AnsattKompetanse → User: Cascade (sletting av User sletter kompetanse-historikk)
// - AnsattKompetanse → Kompetansetype: Restrict (kan ikke slette type med
//   tilknyttede ansatt-rader — krever migrering først)
// ---------------------------------------------------------------------------

model Kompetansetype {
  id                            String   @id @default(uuid())
  organizationId                String   @map("organization_id")
  navn                          String                                          // "M2 Gravemaskin" | "DO CAT 325" | "HMS-kurs 40t"
  kategori                      String                                          // se KOMPETANSE_KATEGORIER
  aktiv                         Boolean  @default(true)
  defaultUtloperAarEtterUtstedt Int?     @map("default_utloper_aar")             // null = ingen default-utløp
  beskrivelse                   String?
  kobletTilEquipmentModell      String?  @map("koblet_til_equipment_modell")    // for DO-kobling Fase 6 (fritekst merke+modell)
  createdAt                     DateTime @default(now()) @map("created_at")
  updatedAt                     DateTime @updatedAt @map("updated_at")

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ansattKompetanser AnsattKompetanse[]

  @@unique([organizationId, navn])
  @@index([organizationId, kategori])
  @@map("kompetansetyper")
}

model AnsattKompetanse {
  id                String    @id @default(uuid())
  userId            String    @map("user_id")
  kompetansetypeId  String    @map("kompetansetype_id")
  utstedtDato       DateTime? @map("utstedt_dato") @db.Date                     // SmartDok kaller det «Fullført dato»
  utloper           DateTime? @db.Date
  utstederOrgan     String?   @map("utsteder_organ")
  sertifikatNr      String?   @map("sertifikat_nr")
  vedlegg           Json?                                                        // [{url, filename, type, uploadedAt}]
  notat             String?
  opprettetAvUserId String?   @map("opprettet_av_user_id")                       // ingen FK — bevarer audit-spor ved User-sletting (A.3-mønster)
  importertVia      String?   @map("importert_via")                              // "manuell" | "csv" | "xlsx" | "hr_api" | "smartdok"
  importertVed      DateTime? @map("importert_ved")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  kompetansetype Kompetansetype @relation(fields: [kompetansetypeId], references: [id], onDelete: Restrict)

  @@unique([userId, kompetansetypeId])
  @@index([utloper])
  @@index([kompetansetypeId])
  @@map("ansatt_kompetanser")
}

// ---------------------------------------------------------------------------
// ProjectGroupByggeplass — m2m mellom ProjectGroup og Byggeplass (Fase 0.5 § 3)
// Per fase-0-beslutninger.md byggeplass-strategi.md § Prinsipp C (C1: koblings-
// tabell) + arkitektur-syntese.md § 5.
//
// Erstatter ProjectGroup.byggeplassIder (jsonb «building_ids»). Per Prinsipp C-
// verifisering 2026-05-01 var jsonb-feltet dødt (skrevet i gruppe.ts:495-503,
// aldri lest noen sted) — derfor ingen data å migrere, dropp i samme migrasjon.
//
// Semantikk: ingen rader for en gruppe = ingen byggeplass-restriksjon
// (gruppen har tilgang til alle byggeplasser). Rader = begrenset til disse
// byggeplassene.
//
// Cascade-policy:
// - ProjectGroupByggeplass → ProjectGroup: Cascade
// - ProjectGroupByggeplass → Byggeplass: Cascade
// ---------------------------------------------------------------------------

model ProjectGroupByggeplass {
  id           String   @id @default(uuid())
  groupId      String   @map("group_id")
  byggeplassId String   @map("byggeplass_id")
  createdAt    DateTime @default(now()) @map("created_at")

  group      ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  byggeplass Byggeplass   @relation(fields: [byggeplassId], references: [id], onDelete: Cascade)

  @@unique([groupId, byggeplassId])
  @@index([byggeplassId])
  @@map("project_group_byggeplasser")
}
