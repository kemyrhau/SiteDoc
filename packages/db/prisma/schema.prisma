generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(uuid())
  name           String?
  // email forblir NOT NULL i Fase 0 (alle har e-post per kunde-bekreftelse).
  // @unique er erstattet av composite @@unique([email, organizationId]) per B.7.
  email          String
  emailVerified  DateTime? @map("email_verified")
  image          String?
  phone          String?
  role           String    @default("user") // "user" | "company_admin" | "sitedoc_admin"
  language       String    @default("nb") // nb, en, sv, lt, pl, uk, ro, et, fi, cs, de, ru, lv
  tabelloppsett  Json?     @map("tabelloppsett") // { [liste]: { kolonner, bredder, sortering } }
  organizationId String?   @map("organization_id")

  // Per A.10 — to bruksområder: data-mottaker uten innloggings-tilgang OG arkivert User-rad ved org-bytte
  canLogin       Boolean   @default(true) @map("can_login")

  // Per A.11 — GDPR data-minimalisering (kun det som brukes for forretning/lov)
  fodselsdato              DateTime?
  nasjonalitet             String?                          // ISO 3166-1 alpha-2 eller fritekst
  hmsKortNr                String?  @map("hms_kort_nr")
  hmsKortUtloper           DateTime? @map("hms_kort_utloper")
  arbeidstillatelse        String?                          // "permanent" | "midlertidig" | null (ingen CHECK i Fase 0)
  arbeidstillatelseUtloper DateTime? @map("arbeidstillatelse_utloper")

  // Per § E steg 13
  ansattnummer             String?

  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Per Fase 0.5 § 1 + C.11 — firma-intern organisatorisk inndeling.
  // SetNull: sletting av Avdeling skal ikke slette brukere.
  avdelingId               String?  @map("avdeling_id")

  organization         Organization?        @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  avdeling             Avdeling?            @relation(fields: [avdelingId], references: [id], onDelete: SetNull)
  accounts             Account[]
  sessions             Session[]
  projects             ProjectMember[]
  bestilteChecklists   Checklist[]          @relation("ChecklistCreator")
  eideChecklists       Checklist[]          @relation("ChecklistOwner")
  bestilteTasks        Task[]               @relation("TaskCreator")
  eideTasks            Task[]               @relation("TaskOwner")
  bestilteGodkjenninger Godkjenning[]        @relation("GodkjenningCreator")
  eideGodkjenninger     Godkjenning[]        @relation("GodkjenningOwner")
  godkjenteGodkjenninger Godkjenning[]       @relation("GodkjenningGodkjenner")
  organizationRoles      OrganizationRole[]
  sentTransfers        DocumentTransfer[]   @relation("TransferSender")
  receivedTransfers    DocumentTransfer[]   @relation("TransferRecipient")
  recipientChecklists  Checklist[]          @relation("ChecklistRecipient")
  recipientTasks       Task[]               @relation("TaskRecipient")
  drawingRevisions     DrawingRevision[]    @relation("DrawingRevisionUploader")
  sentInvitations      ProjectInvitation[]  @relation("InvitationSender")
  folderAccess         FolderAccess[]
  taskComments         TaskComment[]
  checklistChangeLogs  ChecklistChangeLog[]
  ansvarligFaggrupper Faggruppe[] @relation("FaggruppeAnsvarlig")
  psiSignaturer        PsiSignatur[]
  godkjenteKontrollplaner Kontrollplan[] @relation("KontrollplanGodkjenner")
  kontrollplanHistorikk   KontrollplanHistorikk[]
  kompetanser             AnsattKompetanse[]

  @@index([organizationId])
  @@index([avdelingId])
  // Per B.7 — én User per (person × firma). Composite unique tillater Joakim
  // å ha én User-rad per firma han jobber i.
  @@unique([email, organizationId])
  // Per B.7-utvidelse — forberedende for multi-identifikator-auth (telefon-only-bruker)
  @@unique([phone, organizationId])
  @@map("users")
}

model Organization {
  id                 String   @id @default(uuid())
  name               String
  organizationNumber String?  @map("organization_number") // Org.nr (norsk)
  invoiceAddress     String?  @map("invoice_address")
  invoiceEmail       String?  @map("invoice_email")
  ehfEnabled         Boolean  @default(false) @map("ehf_enabled")
  logoUrl            String?  @map("logo_url")
  harMaskinModul     Boolean  @default(false) @map("har_maskin_modul") // Midlertidig firma-modul-flagg — erstattes av OrganizationModule i Fase 0 per A.4
  harTimerModul      Boolean  @default(false) @map("har_timer_modul") // Midlertidig firma-modul-flagg — erstattes av OrganizationModule i Fase 0 per A.4
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  users               User[]
  projects            ProjectOrganization[]
  primaryProjects     Project[]                 @relation("ProjectPrimaryOrg")
  projectModules      ProjectModule[]           @relation("OrgProjectModule")
  partners            OrganizationPartner[]
  templates           OrganizationTemplate[]
  externalCostObjects ExternalCostObject[]
  organizationRoles   OrganizationRole[]
  integrations        OrganizationIntegration[]
  setting             OrganizationSetting?
  avdelinger          Avdeling[]
  kompetansetyper     Kompetansetype[]

  @@map("organizations")
}

model OrganizationIntegration {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  type           String   // "proadm" | "hr" | "gps" | "smartdoc"
  url            String?
  apiKey         String?  @map("api_key") // kryptert i produksjon
  config         Json?    // fleksibelt for leverandør-spesifikke felt
  aktiv          Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@index([organizationId])
  @@map("organization_integrations")
}

// ---------------------------------------------------------------------------
// ProjectOrganization — m:n mellom Project og Organization med rolle
// Per fase-0-beslutninger.md § A.5 + § E steg 3.
// Renamed fra OrganizationProject 2026-05-01 (Fase 0).
// ---------------------------------------------------------------------------

model ProjectOrganization {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  organizationId String   @map("organization_id")
  rolle          String   @default("hovedeier") // "hovedeier" | "byggherre" | "konsulent" | "underentreprenor"
  createdAt      DateTime @default(now()) @map("created_at")

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([projectId, organizationId])
  @@map("project_organizations")
}

// ---------------------------------------------------------------------------
// OrganizationSetting — firma-instillinger (1:1 med Organization)
// Per fase-0-beslutninger.md § A.14 + arkitektur-syntese.md § 1.3 + § 2.4.
// ---------------------------------------------------------------------------

model OrganizationSetting {
  id             String @id @default(cuid())
  organizationId String @unique @map("organization_id")

  // Tidssone for forretningsregler (A.14, B.6)
  timezone String @default("Europe/Oslo")

  // Tilgangs-defaults (§ 1.3 + § 2.4)
  // Verdier: 'alle-ansatte' | 'kun-prosjektmedlemmer' | 'sertifiserte'
  timerTilgangDefault       String @default("alle-ansatte") @map("timer_tilgang_default")
  vareforbrukTilgangDefault String @default("alle-ansatte") @map("vareforbruk_tilgang_default")
  maskinbrukTilgangDefault  String @default("sertifiserte") @map("maskinbruk_tilgang_default")

  // Per Fase 0.5 § 2 — hvem kan registrere AnsattKompetanse-rader
  // Verdier: 'firma_admin' | 'bruker_egen' | 'alle'
  // Default 'firma_admin' (mest restriktivt — kunde løsner opp ved behov)
  kompetanseRegistreringTilgang String @default("firma_admin") @map("kompetanse_registrering_tilgang")

  // Timer-modul (Fase 3 Infrastruktur, vedtatt 2026-05-01)
  // Dagsnorm i timer per arbeidsdag — auto-fordeling til normaltid/overtid
  dagsnorm              Decimal @default(7.5) @map("dagsnorm") @db.Decimal(4, 2)
  // Terskel for overtidsmat-tillegg (timer)
  overtidsmatTerskel    Decimal @default(9.0) @map("overtidsmat_terskel") @db.Decimal(4, 2)
  // Tillater ansatte å attestere egen dagsseddel (selv-attestering)
  tillattSelvAttestering Boolean @default(true) @map("tillatt_selv_attestering")
  // Antall dager før dagsseddel låses for endring (NULL = ingen alders-grense, status styrer låsing)
  timerLockEtterDager   Int?    @map("timer_lock_etter_dager")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_settings")
}

// ---------------------------------------------------------------------------
// OrganizationPartner — firma-eid bibliotek over UE/byggherre/leverandører
// Per fase-0-beslutninger.md § E steg 6 + arkitektur-syntese.md § 3.2 + § 4.
// Bravida med to faggrupper (Elektro, Ventilasjon) på samme prosjekt
// peker til samme partner-rad via Faggruppe.partnerId.
// ---------------------------------------------------------------------------

model OrganizationPartner {
  id                 String   @id @default(cuid())
  organizationId     String   @map("organization_id")
  name               String
  organizationNumber String?  @map("organization_number")
  partnerType        String?  @map("partner_type") // "underentreprenor" | "byggherre" | "leverandor" | "konsulent"
  contactName        String?  @map("contact_name")
  contactEmail       String?  @map("contact_email")
  contactPhone       String?  @map("contact_phone")
  notes              String?
  archived           Boolean  @default(false)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  faggrupper   Faggruppe[]

  @@unique([organizationId, organizationNumber])
  @@index([organizationId])
  @@map("organization_partners")
}

// Auth.js-tabeller for OAuth-tilkoblinger
model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id                        String   @id @default(uuid())
  projectNumber             String   @unique @map("project_number")
  name                      String
  description               String?
  address                   String?
  latitude                  Float?   @map("latitude")
  longitude                 Float?   @map("longitude")
  internalProjectNumber     String?  @map("internal_project_number")
  externalProjectNumber     String?  @map("external_project_number")
  logoUrl                   String?  @map("logo_url")
  showInternalProjectNumber Boolean  @default(true) @map("show_internal_project_number")
  utskriftsinnstillinger     Json?    @map("utskrifts_innstillinger") // { logo, eksternProsjektnummer, prosjektnavn, fraTil, lokasjon, tegningsnummer, vaer }
  sourceLanguage            String   @default("nb") @map("source_language") // Kildespråk for prosjektet
  status                    String   @default("active")
  trialExpiresAt            DateTime? @map("trial_expires_at")
  primaryOrganizationId     String?  @map("primary_organization_id") // Per fase-0-beslutninger.md § E steg 4 (nullable per B.4 interim)
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")

  members              ProjectMember[]
  faggrupper           Faggruppe[]
  drawings             Drawing[]
  pointClouds          PointCloud[]
  byggeplasser         Byggeplass[]
  omrader              Omrade[]
  templates            ReportTemplate[]
  folders              Folder[]
  groups               ProjectGroup[]
  invitations          ProjectInvitation[]
  modules              ProjectModule[]
  projectOrganizations ProjectOrganization[]
  primaryOrganization  Organization?         @relation("ProjectPrimaryOrg", fields: [primaryOrganizationId], references: [id], onDelete: SetNull)
  externalCostObjects  ExternalCostObject[]
  dokumentflyter       Dokumentflyt[]
  ftdDocuments         FtdDocument[]
  ftdSpecPosts         FtdSpecPost[]
  ftdNotaPeriods       FtdNotaPeriod[]
  ftdKontrakter        FtdKontrakt[]
  changeEvents         FtdChangeEvent[]
  psiEr                Psi[]
  kontrollplaner       Kontrollplan[]
  godkjenninger        Godkjenning[]

  @@index([trialExpiresAt])
  @@index([primaryOrganizationId])
  @@map("projects")
}

model ProjectMember {
  id                  String   @id @default(uuid())
  // userId: nullable per B.7 — bevarer ProjectMember-historikk når User slettes (sjelden, vi arkiverer normalt med canLogin = false)
  userId              String?  @map("user_id")
  projectId           String   @map("project_id")
  // role: "admin" | "member" — prosjekt-rang. IKKE "underentreprenor" (per A.9, utledes deterministisk via erUnderentreprenor()).
  role                String   @default("member")
  erFirmaansvarlig    Boolean  @default(false) @map("er_firmaansvarlig")
  // kanAttestere (vedtatt 2026-05-02): kapabilitet for timer-attestering uten å være prosjekt-admin.
  // role="admin" gir implisitt attestering-tilgang via erProsjektLeder. Backfill ved migrering: alle role="admin" får true.
  kanAttestere        Boolean  @default(false) @map("kan_attestere")
  // periodeSlutt: null = aktiv (per B.7 + C.13). createdAt fungerer som periodeStart.
  periodeSlutt        DateTime? @map("periode_slutt")
  createdAt           DateTime @default(now()) @map("created_at")

  user                   User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  project                Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  faggruppeKoblinger     FaggruppeKobling[]
  groupMemberships       ProjectGroupMember[]
  dokumentflytMedlemskap           DokumentflytMedlem[]
  hovedansvarligIDokumentflyter    DokumentflytMedlem[] @relation("HovedansvarligPerson")

  @@unique([userId, projectId])
  @@map("project_members")
}

model FaggruppeKobling {
  id              String    @id @default(uuid())
  projectMemberId String    @map("project_member_id")
  faggruppeId     String    @map("faggruppe_id")
  // periodeSlutt per C.13: null = aktiv. createdAt fungerer som periodeStart.
  periodeSlutt    DateTime? @map("periode_slutt")
  createdAt       DateTime  @default(now()) @map("created_at")

  projectMember ProjectMember  @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)
  faggruppe     Faggruppe      @relation(fields: [faggruppeId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, faggruppeId])
  @@map("dokumentflyt_koblinger")
}

model ProjectGroup {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  name        String
  slug        String
  category    String   @default("field") // generelt, field, brukergrupper
  permissions Json     @default("[]")
  domains     Json     @default("[]") // ["bygg"], ["hms"], ["bygg","hms"], etc.
  modules     Json     @default("[\"sjekklister\",\"oppgaver\",\"tegninger\",\"3d\"]") // aktive moduler
  // building_ids jsonb droppet 2026-05-01 (Fase 0.5 § 3) — erstattet av
  // ProjectGroupByggeplass m2m-koblingstabell. Per Prinsipp C-verifisering var
  // feltet dødt (skrevet, aldri lest) — ingen data å migrere.
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project               Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  members               ProjectGroupMember[]
  invitations           ProjectInvitation[]
  folderAccess          FolderAccess[]
  groupFaggrupper       GroupFaggruppe[]
  dokumentflytMedlemmer DokumentflytMedlem[]
  recipientTransfers    DocumentTransfer[]   @relation("TransferRecipientGroup")
  recipientChecklists   Checklist[]          @relation("ChecklistRecipientGroup")
  recipientTasks        Task[]               @relation("TaskRecipientGroup")
  byggeplasser          ProjectGroupByggeplass[]

  @@unique([projectId, slug])
  @@map("project_groups")
}

model ProjectGroupMember {
  id              String    @id @default(uuid())
  groupId         String    @map("group_id")
  projectMemberId String    @map("project_member_id")
  isAdmin         Boolean   @default(false) @map("is_admin")
  // periodeSlutt per C.13: null = aktiv. createdAt fungerer som periodeStart.
  periodeSlutt    DateTime? @map("periode_slutt")
  createdAt       DateTime  @default(now()) @map("created_at")

  group         ProjectGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)

  @@unique([groupId, projectMemberId])
  @@index([projectMemberId])
  @@map("project_group_members")
}

model GroupFaggruppe {
  id           String   @id @default(uuid())
  groupId      String   @map("group_id")
  faggruppeId  String   @map("faggruppe_id")
  createdAt    DateTime @default(now()) @map("created_at")

  group      ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  faggruppe  Faggruppe    @relation(fields: [faggruppeId], references: [id], onDelete: Cascade)

  @@unique([groupId, faggruppeId])
  @@index([faggruppeId])
  @@map("group_faggrupper")
}

model ProjectInvitation {
  id              String    @id @default(uuid())
  email           String
  token           String    @unique
  projectId       String    @map("project_id")
  role            String    @default("member")
  faggruppeId     String?   @map("faggruppe_id")
  groupId         String?   @map("group_id")
  invitedByUserId String    @map("invited_by_user_id")
  status          String    @default("pending") // pending | accepted | expired
  expiresAt       DateTime  @map("expires_at")
  acceptedAt      DateTime? @map("accepted_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  faggruppe  Faggruppe?    @relation(fields: [faggruppeId], references: [id], onDelete: SetNull)
  group            ProjectGroup?     @relation(fields: [groupId], references: [id], onDelete: SetNull)
  invitedBy        User              @relation("InvitationSender", fields: [invitedByUserId], references: [id])

  @@index([email])
  @@index([expiresAt])
  @@index([projectId, status])
  @@map("project_invitations")
}

model Faggruppe {
  id                 String   @id @default(uuid())
  projectId          String   @map("project_id")
  kontraktId         String?  @map("kontrakt_id")
  partnerId          String?  @map("partner_id") // FK til OrganizationPartner-bibliotek (nullable — kunde-drevet migrering fra companyName)
  name               String
  faggruppeNummer    String?  @map("faggruppe_nummer")
  organizationNumber String?  @map("organization_number")
  color              String?
  industry           String?
  companyName        String?  @map("company_name")
  ansvarligId        String?  @map("ansvarlig_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  project                Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kontrakt               FtdKontrakt?         @relation(fields: [kontraktId], references: [id], onDelete: SetNull)
  partner                OrganizationPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  ansvarlig              User?                @relation("FaggruppeAnsvarlig", fields: [ansvarligId], references: [id], onDelete: SetNull)
  faggruppeKoblinger     FaggruppeKobling[]
  bestillerChecklists    Checklist[]          @relation("ChecklistBestillerFaggruppe")
  utforerChecklists      Checklist[]          @relation("ChecklistUtforerFaggruppe")
  bestillerTasks         Task[]               @relation("TaskBestillerFaggruppe")
  utforerTasks           Task[]               @relation("TaskUtforerFaggruppe")
  bestillerGodkjenninger Godkjenning[]        @relation("GodkjenningBestillerFaggruppe")
  utforerGodkjenninger   Godkjenning[]        @relation("GodkjenningUtforerFaggruppe")
  dokumentflytMedlemskap DokumentflytMedlem[]
  dokumentflyter         Dokumentflyt[]       @relation("dokumentflytFaggruppe")
  invitations            ProjectInvitation[]
  folderAccess           FolderAccess[]
  groupFaggrupper        GroupFaggruppe[]
  ftdNotaPeriods         FtdNotaPeriod[]
  kontrollplanPunkter    KontrollplanPunkt[]

  @@index([projectId])
  @@index([kontraktId])
  @@index([partnerId])
  @@index([ansvarligId])
  @@map("dokumentflyt_parts")
}

model Drawing {
  id               String    @id @default(uuid())
  projectId        String    @map("project_id")
  byggeplassId     String?   @map("byggeplass_id")
  name             String
  drawingNumber    String?   @map("drawing_number") // Tegningsnummer: ARK-P-101
  discipline       String? // Fagdisiplin: ARK, RIB, RIV, RIE, RIBr, RIG, LARK, RIAku
  drawingType      String?   @map("drawing_type") // Tegningstype: plan, snitt, fasade, detalj, oversikt, skjema
  revision         String    @default("A") // Revisjonskode: A, B, C eller R01, R02
  version          Int       @default(1) // Internversjon (økes ved opplasting)
  status           String    @default("utkast") // utkast, delt, under_behandling, godkjent, for_bygging, som_bygget
  floor            String? // Etasje: U2, U1, 01, 02, 03, Tak
  scale            String? // Målestokk: 1:50, 1:100, 1:200
  description      String? // Innholdsbeskrivelse
  originator       String? // Opphav (firma/person)
  fileUrl          String    @map("file_url")
  fileType         String    @map("file_type") // PDF, DWG, DXF, IFC
  fileSize         Int?      @map("file_size") // Filstørrelse i bytes
  imageWidth       Int?      @map("image_width") // Bildets bredde i piksler (for tegningsposisjon i PDF)
  imageHeight      Int?      @map("image_height") // Bildets høyde i piksler
  originalFileUrl  String?   @map("original_file_url") // Original DWG-fil (før konvertering)
  coordinateSystem String?   @map("coordinate_system") // Detektert koordinatsystem (utm33, ntm6, etc.)
  conversionStatus String?   @map("conversion_status") // pending, converting, done, failed
  conversionError  String?   @map("conversion_error") // Feilmelding ved konvertering
  issuedAt         DateTime? @map("issued_at") // Utstedelsesdato
  geoReference     Json?     @map("geo_reference") // Georeferanse med 2 referansepunkter
  ifcMetadata      Json?     @map("ifc_metadata") // Uttrukket IFC-metadata (prosjekt, organisasjon, etasjer, GPS)
  gpsOverride      Json?     @map("gps_override") // Manuell GPS-kalibrering for IFC: {lat, lng} — overstyrer ifcMetadata GPS
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byggeplass Byggeplass?       @relation(fields: [byggeplassId], references: [id], onDelete: SetNull)
  revisions  DrawingRevision[]
  tasks      Task[]
  checklists Checklist[]
  omrader    Omrade[]

  @@index([projectId])
  @@index([byggeplassId])
  @@index([status])
  @@map("drawings")
}

model PointCloud {
  id                String   @id @default(uuid())
  projectId         String   @map("project_id")
  byggeplassId      String?  @map("byggeplass_id")
  name              String
  description       String?
  fileUrl           String   @map("file_url") // Opplastet fil (LAS, LAZ, E57, PLY)
  fileType          String   @map("file_type") // las, laz, e57, ply
  fileSize          Int?     @map("file_size")
  potreeUrl         String?  @map("potree_url") // Sti til Potree-output (metadata.json)
  conversionStatus  String   @default("pending") @map("conversion_status") // pending, converting, done, failed
  conversionError   String?  @map("conversion_error")
  coordinateSystem  String?  @map("coordinate_system") // utm33, ntm6, etc.
  pointCount        Int?     @map("point_count") // Antall punkter
  hasClassification Boolean  @default(false) @map("has_classification")
  hasRgb            Boolean  @default(false) @map("has_rgb")
  classifications   Json? // [{kode: 2, navn: "Bakke", antall: 50000}, ...]
  boundingBox       Json?    @map("bounding_box") // {min: {x,y,z}, max: {x,y,z}}
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byggeplass Byggeplass? @relation(fields: [byggeplassId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([byggeplassId])
  @@map("point_clouds")
}

model DrawingRevision {
  id           String    @id @default(uuid())
  drawingId    String    @map("drawing_id")
  revision     String // Revisjonskode ved denne versjonen (A, B, C)
  version      Int // Versjonsnummer ved denne revisjonen
  fileUrl      String    @map("file_url")
  fileSize     Int?      @map("file_size")
  description  String? // Beskrivelse av endringer
  uploadedById String?   @map("uploaded_by_id")
  status       String // Status ved revisjon
  issuedAt     DateTime? @map("issued_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  drawing    Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("DrawingRevisionUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([drawingId])
  @@index([uploadedById])
  @@map("drawing_revisions")
}

model Byggeplass {
  id          String   @id @default(uuid())
  projectId   String   @map("project_id")
  number      Int?     @map("number")
  name        String
  description String?
  address     String?
  type        String   @default("bygg") // "bygg" | "anlegg"
  status      String   @default("unpublished")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  project          Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  drawings         Drawing[]
  pointClouds      PointCloud[]
  checklists       Checklist[]
  ftdKontrakter    FtdKontrakt[]
  gruppeKoblinger  ProjectGroupByggeplass[]
  psiEr            Psi[]
  omrader          Omrade[]
  kontrollplaner   Kontrollplan[]

  @@index([status])
  @@map("byggeplasser")
}

model Omrade {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  byggeplassId  String   @map("byggeplass_id")
  tegningId     String?  @map("tegning_id")
  navn          String
  type          String   @default("sone")     // sone | rom | etasje
  polygon       Json     @default("[]")       // [{x: number, y: number}, ...]
  farge         String   @default("#3b82f6")
  sortering     Int      @default(0)
  opprettet     DateTime @default(now())

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byggeplass Byggeplass @relation(fields: [byggeplassId], references: [id], onDelete: Cascade)
  tegning    Drawing?   @relation(fields: [tegningId], references: [id], onDelete: SetNull)
  kontrollplanPunkter KontrollplanPunkt[]

  @@index([projectId])
  @@index([byggeplassId])
  @@index([tegningId])
  @@map("omrader")
}

model ReportTemplate {
  id              String   @id @default(uuid())
  projectId       String   @map("project_id")
  name            String
  description     String?
  prefix          String?
  category        String   @default("sjekkliste") // "oppgave" | "sjekkliste"
  domain          String   @default("bygg") // "bygg" | "hms" | "kvalitet"
  subjects        Json?    @default("[]") // Forhåndsdefinerte emnetekster ["3. etasje", "Kjeller", ...]
  showSubject     Boolean  @default(true) @map("show_subject")
  showFaggruppe   Boolean  @default(true) @map("show_faggruppe")
  showLocation    Boolean  @default(true) @map("show_location")
  showPriority    Boolean  @default(true) @map("show_priority")
  version         Int      @default(1)
  enableChangeLog Boolean  @default(false) @map("enable_change_log")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  kontrollomrade    String?            @map("kontrollomrade") // fukt | brann | konstruksjon | geo | grunnarbeid | sha | null

  // Mal-promotering (per fase-0-beslutninger.md § E steg 7 — forberedelse til Fase 2)
  organizationTemplateId String?  @map("organization_template_id") // Peker oppover hvis kopiert fra firma-mal
  promotedToFirma        Boolean  @default(false) @map("promoted_to_firma") // True hvis denne mal er promotert til firma-bibliotek

  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  objects           ReportObject[]
  checklists        Checklist[]
  tasks             Task[]
  godkjenninger     Godkjenning[]
  dokumentflytMaler DokumentflytMal[]
  psi               Psi[]
  kontrollplanPunkter KontrollplanPunkt[]

  copiedFromOrgTemplate OrganizationTemplate?  @relation("CopiedFromOrgTemplate", fields: [organizationTemplateId], references: [id], onDelete: SetNull)
  promotedTo            OrganizationTemplate[] @relation("PromotedTemplate")

  @@index([organizationTemplateId])
  @@map("report_templates")
}

model ReportObject {
  id         String   @id @default(uuid())
  templateId String   @map("template_id")
  parentId   String?  @map("parent_id")
  type       String
  label      String
  config       Json     @default("{}")
  translations Json     @default("{}") // i18n: { "en": { label, content, question, options, caption }, ... }
  sortOrder    Int      @map("sort_order")
  required     Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  template ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent   ReportObject?  @relation("ObjektHierarki", fields: [parentId], references: [id], onDelete: Cascade)
  children ReportObject[] @relation("ObjektHierarki")

  @@index([parentId])
  @@map("report_objects")
}

// ---------------------------------------------------------------------------
// OrganizationTemplate — firma-eid mal-bibliotek (mal-promotering)
// Per fase-0-beslutninger.md § E steg 7 + migrering-reporttemplate.md.
// Speiler ReportTemplate-strukturen, men eid av Organization.
// API-ruter (firmamal.*) og UI bygges i Fase 2.
// ---------------------------------------------------------------------------

model OrganizationTemplate {
  id                     String   @id @default(uuid())
  organizationId         String   @map("organization_id")
  name                   String
  description            String?
  prefix                 String?
  category               String   @default("sjekkliste") // "oppgave" | "sjekkliste"
  domain                 String   @default("bygg")        // "bygg" | "hms" | "kvalitet"
  subjects               Json?    @default("[]")
  showSubject            Boolean  @default(true) @map("show_subject")
  showFaggruppe          Boolean  @default(true) @map("show_faggruppe")
  showLocation           Boolean  @default(true) @map("show_location")
  showPriority           Boolean  @default(true) @map("show_priority")
  version                Int      @default(1)
  enableChangeLog        Boolean  @default(false) @map("enable_change_log")
  kontrollomrade         String?
  promotedFromTemplateId String?  @map("promoted_from_template_id")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  organization Organization                 @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  promotedFrom ReportTemplate?              @relation("PromotedTemplate", fields: [promotedFromTemplateId], references: [id], onDelete: SetNull)
  objects      OrganizationTemplateObject[]
  copiedTo     ReportTemplate[]             @relation("CopiedFromOrgTemplate")

  @@index([organizationId])
  @@index([promotedFromTemplateId])
  @@map("organization_templates")
}

model OrganizationTemplateObject {
  id           String   @id @default(uuid())
  templateId   String   @map("template_id")
  parentId     String?  @map("parent_id")
  type         String
  label        String
  config       Json     @default("{}")
  translations Json     @default("{}")
  sortOrder    Int      @map("sort_order")
  required     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  template OrganizationTemplate         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent   OrganizationTemplateObject?  @relation("OrgObjektHierarki", fields: [parentId], references: [id], onDelete: Cascade)
  children OrganizationTemplateObject[] @relation("OrgObjektHierarki")

  @@index([templateId])
  @@index([parentId])
  @@map("organization_template_objects")
}

model Checklist {
  id                    String    @id @default(uuid())
  templateId              String    @map("template_id")
  bestillerUserId         String    @map("bestiller_user_id")
  bestillerFaggruppeId    String    @map("bestiller_faggruppe_id")
  utforerFaggruppeId      String    @map("utforer_faggruppe_id")
  eierUserId              String?   @map("eier_user_id")
  status                  String    @default("draft")
  title                   String
  number                  Int?      @map("number")
  data                    Json      @default("{}")
  dueDate                 DateTime? @map("due_date")
  dokumentflytId          String?   @map("dokumentflyt_id")
  subject                 String?
  byggeplassId            String?   @map("byggeplass_id")
  drawingId             String?   @map("drawing_id")
  positionX             Float?    @map("position_x")
  positionY             Float?    @map("position_y")
  recipientUserId       String?   @map("recipient_user_id")
  recipientGroupId      String?   @map("recipient_group_id")
  lestAvMottakerVed     DateTime? @map("lest_av_mottaker_ved")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  template              ReportTemplate       @relation(fields: [templateId], references: [id])
  bestiller             User                 @relation("ChecklistCreator", fields: [bestillerUserId], references: [id])
  bestillerFaggruppe    Faggruppe            @relation("ChecklistBestillerFaggruppe", fields: [bestillerFaggruppeId], references: [id])
  utforerFaggruppe      Faggruppe            @relation("ChecklistUtforerFaggruppe", fields: [utforerFaggruppeId], references: [id])
  eier                  User?                @relation("ChecklistOwner", fields: [eierUserId], references: [id], onDelete: SetNull)
  dokumentflyt          Dokumentflyt?        @relation(fields: [dokumentflytId], references: [id], onDelete: SetNull)
  byggeplass            Byggeplass?          @relation(fields: [byggeplassId], references: [id], onDelete: SetNull)
  drawing             Drawing?             @relation(fields: [drawingId], references: [id], onDelete: SetNull)
  recipientUser       User?                @relation("ChecklistRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientGroup      ProjectGroup?        @relation("ChecklistRecipientGroup", fields: [recipientGroupId], references: [id], onDelete: SetNull)
  transfers           DocumentTransfer[]
  images              Image[]
  tasks               Task[]
  changeLog           ChecklistChangeLog[]
  kontrollplanPunkt   KontrollplanPunkt?

  @@index([templateId])
  @@index([bestillerUserId])
  @@index([recipientUserId])
  @@index([dueDate])
  @@index([status])
  @@index([dokumentflytId, status])
  @@map("checklists")
}

model Task {
  id                    String    @id @default(uuid())
  templateId              String?   @map("template_id")
  bestillerUserId         String    @map("bestiller_user_id")
  bestillerFaggruppeId    String?   @map("bestiller_faggruppe_id")
  utforerFaggruppeId      String?   @map("utforer_faggruppe_id")
  eierUserId              String?   @map("eier_user_id")
  status                  String    @default("draft")
  title                   String
  description             String?
  subject                 String?
  number                  Int?      @map("number")
  priority                String    @default("medium")
  dueDate                 DateTime? @map("due_date")
  drawingId               String?   @map("drawing_id")
  positionX               Float?    @map("position_x")
  positionY               Float?    @map("position_y")
  dokumentflytId          String?   @map("dokumentflyt_id")
  checklistId           String?   @map("checklist_id")
  checklistFieldId      String?   @map("checklist_field_id")
  data                  Json?
  recipientUserId       String?   @map("recipient_user_id")
  recipientGroupId      String?   @map("recipient_group_id")
  lestAvMottakerVed     DateTime? @map("lest_av_mottaker_ved")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  template              ReportTemplate?    @relation(fields: [templateId], references: [id])
  bestiller             User               @relation("TaskCreator", fields: [bestillerUserId], references: [id])
  bestillerFaggruppe    Faggruppe?         @relation("TaskBestillerFaggruppe", fields: [bestillerFaggruppeId], references: [id])
  utforerFaggruppe      Faggruppe?         @relation("TaskUtforerFaggruppe", fields: [utforerFaggruppeId], references: [id])
  eier                  User?              @relation("TaskOwner", fields: [eierUserId], references: [id], onDelete: SetNull)
  drawing               Drawing?           @relation(fields: [drawingId], references: [id])
  dokumentflyt          Dokumentflyt?      @relation(fields: [dokumentflytId], references: [id], onDelete: SetNull)
  checklist           Checklist?         @relation(fields: [checklistId], references: [id], onDelete: SetNull)
  recipientUser       User?              @relation("TaskRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientGroup      ProjectGroup?      @relation("TaskRecipientGroup", fields: [recipientGroupId], references: [id], onDelete: SetNull)
  transfers           DocumentTransfer[]
  images              Image[]
  comments            TaskComment[]

  @@index([templateId])
  @@index([bestillerUserId])
  @@index([recipientUserId])
  @@index([dueDate])
  @@index([status])
  @@index([dokumentflytId, status])
  @@map("tasks")
}

// ---------------------------------------------------------------------------
// Godkjenning — utvidet dokumentflyt-type for byggherre-godkjenning av kostnad
// Per fase-0-beslutninger.md § A.2 + § E steg 12.
// Følger Checklist/Task/Psi-mønsteret. Forhandlingshistorikk og kostnad-snapshot
// lagres på DocumentTransfer-radene (kostnadSnapshot Json) — én rad per
// send/retur/godkjenning. Restrict-default for bestiller/faggruppe-FK-er
// (sletting blokkeres når godkjenninger eksisterer).
// ---------------------------------------------------------------------------

model Godkjenning {
  id                    String    @id @default(uuid())
  templateId            String?   @map("template_id")
  projectId             String    @map("project_id")
  bestillerUserId       String    @map("bestiller_user_id")
  bestillerFaggruppeId  String    @map("bestiller_faggruppe_id")
  utforerFaggruppeId    String    @map("utforer_faggruppe_id")
  eierUserId            String?   @map("eier_user_id")
  status                String    @default("draft")
  dokumentflytId        String?   @map("dokumentflyt_id")

  externalCostObjectId  String?   @map("external_cost_object_id")
  internRef             String?   @map("intern_ref")
  byggherreRef          String?   @map("byggherre_ref")
  kortNavn              String    @map("kort_navn")

  // Per B.6 — godkjenning får Timestamptz på alle tidsstempler
  godkjentVed           DateTime? @db.Timestamptz @map("godkjent_ved")
  godkjentAvUserId      String?   @map("godkjent_av_user_id")

  // Per B.3 (lukket 2026-04-27)
  endretEtterSending    Boolean   @default(false) @map("endret_etter_sending")
  sistEndretVed         DateTime? @db.Timestamptz @map("sist_endret_ved")

  createdAt             DateTime  @default(now()) @db.Timestamptz @map("created_at")
  updatedAt             DateTime  @updatedAt @db.Timestamptz @map("updated_at")

  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template             ReportTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  bestiller            User                 @relation("GodkjenningCreator", fields: [bestillerUserId], references: [id])
  bestillerFaggruppe   Faggruppe            @relation("GodkjenningBestillerFaggruppe", fields: [bestillerFaggruppeId], references: [id])
  utforerFaggruppe     Faggruppe            @relation("GodkjenningUtforerFaggruppe", fields: [utforerFaggruppeId], references: [id])
  eier                 User?                @relation("GodkjenningOwner", fields: [eierUserId], references: [id], onDelete: SetNull)
  dokumentflyt         Dokumentflyt?        @relation(fields: [dokumentflytId], references: [id], onDelete: SetNull)
  externalCostObject   ExternalCostObject?  @relation(fields: [externalCostObjectId], references: [id], onDelete: SetNull)
  godkjentAv           User?                @relation("GodkjenningGodkjenner", fields: [godkjentAvUserId], references: [id], onDelete: SetNull)
  transfers            DocumentTransfer[]

  @@unique([projectId, internRef])
  @@index([projectId, status])
  @@index([externalCostObjectId])
  @@index([dokumentflytId])
  @@map("godkjenninger")
}

model DocumentTransfer {
  id               String   @id @default(uuid())
  checklistId      String?  @map("checklist_id")
  taskId           String?  @map("task_id")
  godkjenningId    String?  @map("godkjenning_id") // Per A.2 — gjenbruker transfer-mekanisme for Godkjenning
  senderId         String   @map("sender_id")
  recipientUserId  String?  @map("recipient_user_id")
  recipientGroupId String?  @map("recipient_group_id")
  fromStatus       String   @map("from_status")
  toStatus         String   @map("to_status")
  comment          String?
  createdAt        DateTime @default(now()) @map("created_at")

  // Snapshot-felt — fanger kontekst ved tidspunktet hendelsen skjedde
  senderEnterpriseName    String?  @map("sender_enterprise_name")
  recipientEnterpriseName String?  @map("recipient_enterprise_name")
  dokumentflytName        String?  @map("dokumentflyt_name")
  senderRolle             String?  @map("sender_rolle") // bestiller | utforer | godkjenner | registrator
  // Kostnad-snapshot per A.2 — én rad per send/retur/godkjenn lagrer hele forhandlingshistorikken
  kostnadSnapshot         Json?    @map("kostnad_snapshot")

  checklist      Checklist?    @relation(fields: [checklistId], references: [id])
  task           Task?         @relation(fields: [taskId], references: [id])
  godkjenning    Godkjenning?  @relation(fields: [godkjenningId], references: [id], onDelete: Cascade)
  sender         User          @relation("TransferSender", fields: [senderId], references: [id])
  recipientUser  User?         @relation("TransferRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  recipientGroup ProjectGroup? @relation("TransferRecipientGroup", fields: [recipientGroupId], references: [id], onDelete: SetNull)

  @@index([senderId])
  @@index([godkjenningId])
  @@map("document_transfers")
}

model Image {
  id          String   @id @default(uuid())
  checklistId String?  @map("checklist_id")
  taskId      String?  @map("task_id")
  fileUrl     String   @map("file_url")
  fileName    String   @map("file_name")
  fileSize    Int      @map("file_size")
  gpsLat      Float?   @map("gps_lat")
  gpsLng      Float?   @map("gps_lng")
  gpsEnabled  Boolean  @default(true) @map("gps_enabled")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  checklist Checklist? @relation(fields: [checklistId], references: [id])
  task      Task?      @relation(fields: [taskId], references: [id])

  @@index([checklistId])
  @@index([taskId])
  @@map("images")
}

model Folder {
  id         String   @id @default(uuid())
  projectId  String   @map("project_id")
  parentId   String?  @map("parent_id")
  kontraktId String?  @map("kontrakt_id")
  name       String
  accessMode String   @default("inherit") @map("access_mode") // "inherit" | "custom"
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  languages      String[] @default(["nb"]) // Målspråk for dokumentoversettelse
  languageMode   String   @default("inherit") @map("language_mode") // "inherit" | "custom"

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent        Folder?        @relation("FolderHierarchy", fields: [parentId], references: [id])
  children      Folder[]       @relation("FolderHierarchy")
  kontrakt      FtdKontrakt?   @relation(fields: [kontraktId], references: [id], onDelete: SetNull)
  accessEntries FolderAccess[]
  ftdDocuments  FtdDocument[]

  @@index([kontraktId])
  @@map("folders")
}

model FolderAccess {
  id           String   @id @default(uuid())
  folderId     String   @map("folder_id")
  accessType   String   @map("access_type") // "faggruppe" | "group" | "user"
  faggruppeId  String?  @map("faggruppe_id")
  groupId      String?  @map("group_id")
  userId       String?  @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  folder     Folder        @relation(fields: [folderId], references: [id], onDelete: Cascade)
  faggruppe  Faggruppe?    @relation(fields: [faggruppeId], references: [id], onDelete: Cascade)
  group      ProjectGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([folderId, accessType, faggruppeId, groupId, userId])
  @@index([userId])
  @@index([faggruppeId])
  @@index([groupId])
  @@map("folder_access")
}

// ---- Dokumentflyt ----

model Dokumentflyt {
  id           String   @id @default(uuid())
  projectId    String   @map("project_id")
  faggruppeId  String?  @map("faggruppe_id")
  name         String
  roller       Json     @default("[]") // Array<{ rolle: string, label?: string | null }>
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  faggruppe     Faggruppe?           @relation("dokumentflytFaggruppe", fields: [faggruppeId], references: [id], onDelete: SetNull)
  medlemmer     DokumentflytMedlem[]
  maler         DokumentflytMal[]
  checklists    Checklist[]
  tasks         Task[]
  godkjenninger Godkjenning[]

  @@index([projectId])
  @@index([faggruppeId])
  @@map("dokumentflyter")
}

model DokumentflytMedlem {
  id                      String    @id @default(uuid())
  dokumentflytId          String    @map("dokumentflyt_id")
  faggruppeId             String?   @map("faggruppe_id")
  projectMemberId         String?   @map("project_member_id")
  groupId                 String?   @map("group_id")
  hovedansvarligPersonId  String?   @map("hovedansvarlig_person_id") // Spesifikk person i gruppen som er hovedansvarlig
  rolle                   String // "registrator" | "bestiller" | "utforer" | "godkjenner"
  steg                    Int       @default(1)
  erHovedansvarlig        Boolean   @default(false) @map("er_hovedansvarlig")
  kanRedigere             Boolean   @default(true) @map("kan_redigere")
  låsesEtterPasseringer   Int?      @map("laases_etter_passeringer")
  // periodeSlutt per C.13: null = aktiv. createdAt fungerer som periodeStart.
  periodeSlutt            DateTime? @map("periode_slutt")
  createdAt               DateTime  @default(now()) @map("created_at")

  dokumentflyt          Dokumentflyt   @relation(fields: [dokumentflytId], references: [id], onDelete: Cascade)
  faggruppe             Faggruppe?     @relation(fields: [faggruppeId], references: [id], onDelete: Cascade)
  projectMember         ProjectMember? @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)
  group                 ProjectGroup?  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  hovedansvarligPerson  ProjectMember? @relation("HovedansvarligPerson", fields: [hovedansvarligPersonId], references: [id], onDelete: SetNull)

  @@unique([dokumentflytId, faggruppeId, rolle, steg])
  @@unique([dokumentflytId, projectMemberId, rolle, steg])
  @@unique([dokumentflytId, groupId, rolle, steg])
  @@index([projectMemberId])
  @@index([faggruppeId])
  @@index([groupId])
  @@map("dokumentflyt_medlemmer")
}

model DokumentflytMal {
  id             String   @id @default(uuid())
  dokumentflytId String   @map("dokumentflyt_id")
  templateId     String   @map("template_id")
  createdAt      DateTime @default(now()) @map("created_at")

  dokumentflyt Dokumentflyt   @relation(fields: [dokumentflytId], references: [id], onDelete: Cascade)
  template     ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([dokumentflytId, templateId])
  @@map("dokumentflyt_maler")
}

// ---------------------------------------------------------------------------
// ProjectModule — modul-aktivering per prosjekt (utvidet i Fase 0 § E steg 5)
// Per fase-0-beslutninger.md § A.4 + § A.17 + § A.18 (to-stegs migration).
// `active Boolean` beholdes parallelt med `status String` til steg 2
// (post-Fase 1) når all kode er bekreftet å bruke status.
// ---------------------------------------------------------------------------

model ProjectModule {
  id             String   @id @default(uuid())
  projectId      String   @map("project_id")
  moduleSlug     String   @map("module_slug")
  organizationId String?  @map("organization_id") // Nullable per B.4 interim
  active         Boolean  @default(true)           // Beholdes — dropper i steg 2
  status         String   @default("aktiv")        // "aktiv" | "arkivert" | "slettet" (per A.17)
  config         Json?                              // Modulspesifikk konfigurasjon (f.eks. oversettelsesmotor)
  createdAt      DateTime @default(now()) @map("created_at")

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization Organization? @relation("OrgProjectModule", fields: [organizationId], references: [id], onDelete: SetNull)

  @@unique([projectId, moduleSlug])  // Endres til (projectId, organizationId, moduleSlug) i steg 2
  @@index([organizationId])
  @@map("project_modules")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  userId    String   @map("user_id")
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@map("task_comments")
}

model ChecklistChangeLog {
  id          String   @id @default(uuid())
  checklistId String   @map("checklist_id")
  userId      String   @map("user_id")
  fieldId     String   @map("field_id")
  fieldLabel  String   @map("field_label")
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  createdAt   DateTime @default(now()) @map("created_at")

  checklist Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@index([checklistId])
  @@map("checklist_change_log")
}

// ============================================================
// FTD-MODUL: Dokumenthåndtering og mengde/økonomi
// Tabellene er aktive kun når modul "okonomi" eller
// "dokumentsok" er aktivert for prosjektet.
// Dokumenter lever i mapper — tilgang til mapper styrer
// søkbarhet og synlighet av økonomidata.
// ============================================================

model FtdDocument {
  id              String   @id @default(cuid())
  projectId       String   @map("project_id")
  folderId        String?  @map("folder_id")
  kontraktId      String?  @map("kontrakt_id")
  filename        String
  fileUrl         String?  @map("file_url")
  filetype        String?
  docType         String?  @map("doc_type")
  isActive        Boolean  @default(true) @map("is_active")
  sourceLanguage    String   @default("nb") @map("source_language") // Kildespråk for dokumentet (nb, en, etc.)
  detectedLanguage  String?  @map("detected_language") // Auto-detektert språk (null = ikke detektert ennå)
  languageConfirmed Boolean  @default(false) @map("language_confirmed") // Bruker har bekreftet språk ved avvik
  processingState   String   @default("pending") @map("processing_state")
  processingError String?  @map("processing_error")
  fileHash        String?  @map("file_hash")
  standardNumber  String?  @map("standard_number")
  fileSize        Int?     @map("file_size")
  version         Int      @default(1)
  kontraktNavn    String?  @map("kontrakt_navn")
  notaType        String?  @map("nota_type") // "A-Nota" | "T-Nota" | "Sluttnota"
  notaNr          Int?     @map("nota_nr")
  entreprenor     String?  @map("entreprenor")
  pageCount       Int?     @map("page_count")
  wordCount       Int?     @map("word_count")
  splitSources    Json?    @map("split_sources") // [{filnavn, dokumentId, kildeSider, startSide}]

  // Header-verdier fra A-nota/Sluttnota PDF
  utfortPr              DateTime? @map("utfort_pr")
  utfortTotalt          Decimal?  @map("utfort_totalt") @db.Decimal(18, 2)
  utfortForrige         Decimal?  @map("utfort_forrige") @db.Decimal(18, 2)
  utfortDenne           Decimal?  @map("utfort_denne") @db.Decimal(18, 2)
  innestaaende          Decimal?  @map("innestaaende") @db.Decimal(18, 2)
  innestaaendeForrige   Decimal?  @map("innestaaende_forrige") @db.Decimal(18, 2)
  innestaaendeDenne     Decimal?  @map("innestaaende_denne") @db.Decimal(18, 2)
  nettoDenne            Decimal?  @map("netto_denne") @db.Decimal(18, 2)
  mva                   Decimal?  @map("mva") @db.Decimal(18, 2)
  sumInkMva             Decimal?  @map("sum_ink_mva") @db.Decimal(18, 2)

  uploadedAt      DateTime @default(now()) @map("uploaded_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  project   Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder    Folder?              @relation(fields: [folderId], references: [id], onDelete: SetNull)
  kontrakt  FtdKontrakt?         @relation(fields: [kontraktId], references: [id], onDelete: SetNull)
  chunks    FtdDocumentChunk[]
  specPosts    FtdSpecPost[]
  pages        FtdDocumentPage[]
  notaPerioder FtdNotaPeriod[]
  changeEvents FtdChangeEvent[]
  tnotaLinks   FtdTnotaChangeLink[]

  @@unique([projectId, filename])
  @@index([folderId])
  @@index([kontraktId])
  @@index([processingState])
  @@map("ftd_documents")
}

model FtdKontrakt {
  id                   String   @id @default(cuid())
  projectId            String   @map("project_id")
  navn                 String
  kontraktType         String?  @map("kontrakt_type") // "8405" | "8406" | "8407"
  byggherre            String?
  entreprenor          String?
  byggeplassId         String?  @map("byggeplass_id")
  hmsSamordningsgruppe String?  @map("hms_samordningsgruppe")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  byggeplass Byggeplass? @relation(fields: [byggeplassId], references: [id], onDelete: SetNull)
  faggrupper   Faggruppe[]
  dokumenter   FtdDocument[]
  mapper       Folder[]
  notaPerioder FtdNotaPeriod[]
  changeEvents FtdChangeEvent[]

  @@index([projectId])
  @@map("ftd_kontrakter")
}

model FtdChangeEvent {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  kontraktId    String?  @map("kontrakt_id")
  eventType     String   @map("event_type") // varsel | varsel_om_endring | endringsmelding | regningsarbeid
  eventNumber   String?  @map("event_number")
  description   String?
  sentToBhAt    DateTime? @map("sent_to_bh_at")
  documentId    String?  @map("document_id")
  createdAt     DateTime @default(now()) @map("created_at")

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kontrakt  FtdKontrakt? @relation(fields: [kontraktId], references: [id], onDelete: SetNull)
  document  FtdDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  tnotaLinks FtdTnotaChangeLink[]

  @@index([projectId])
  @@map("ftd_change_events")
}

model FtdTnotaChangeLink {
  id              String @id @default(cuid())
  tnotaDocumentId String @map("tnota_document_id")
  changeEventId   String @map("change_event_id")

  tnotaDocument FtdDocument    @relation(fields: [tnotaDocumentId], references: [id], onDelete: Cascade)
  changeEvent   FtdChangeEvent @relation(fields: [changeEventId], references: [id], onDelete: Cascade)

  @@unique([tnotaDocumentId, changeEventId])
  @@index([changeEventId])
  @@map("ftd_tnota_change_links")
}

model FtdDocumentChunk {
  id              String                          @id @default(cuid())
  documentId      String                          @map("document_id")
  chunkIndex      Int                             @map("chunk_index")
  chunkText       String                          @map("chunk_text")
  pageNumber      Int?                            @map("page_number")
  sectionTitle    String?                         @map("section_title")
  sectionLevel    Int?                            @map("section_level")
  pageHeading     String?                         @map("page_heading")
  nsCode          String?                         @map("ns_code")
  headingNumber   String?                         @map("heading_number")
  embeddingState  String                          @default("pending") @map("embedding_state")
  profile         String?
  embeddingVector Unsupported("vector(768)")?     @map("embedding_vector")

  document FtdDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([embeddingState])
  @@index([nsCode])
  @@map("ftd_document_chunks")
}

// Blokkbasert dokumentinnhold — brukes for flerspråklig dokumentvisning
model FtdDocumentBlock {
  id            String  @id @default(cuid())
  documentId    String  @map("document_id")
  sortOrder     Int     @map("sort_order")
  pageNumber    Int     @map("page_number")
  blockType     String  @map("block_type")       // "heading" | "text" | "image" | "caption" | "table"
  language      String  @default("nb")
  content       String                            // Tekst for heading/text/caption, JSON for table, tom for image
  sourceBlockId String? @map("source_block_id")   // Peker til norsk original (null for nb)
  headingLevel  Int?    @map("heading_level")     // 1-6 for heading-blokker
  imageUrl      String? @map("image_url")         // S3-URL for ekstraherte bilder

  // Embedding for flerspråklig søk
  embeddingState  String                       @default("pending") @map("embedding_state")
  embeddingVector Unsupported("vector(768)")?  @map("embedding_vector")
  embeddingModel  String?                      @map("embedding_model") // "multilingual-e5-base" | "norbert2"

  // Ingen Prisma-relasjon til FtdDocument — bruker rå SQL for å unngå rekursive typer i tRPC
  // FK constraint finnes i SQL: document_id → ftd_documents(id) ON DELETE CASCADE

  @@index([documentId, language, sortOrder])
  @@index([embeddingState])
  @@index([sourceBlockId])
  @@map("ftd_document_blocks")
}

// Oversettelsesoppdrag — sporer asynkron oversettelse av dokumentblokker
model FtdTranslationJob {
  id          String   @id @default(cuid())
  documentId  String   @map("document_id")
  targetLang  String   @map("target_lang")
  status      String   @default("pending")  // pending | processing | done | failed
  error       String?
  blocksTotal Int      @default(0) @map("blocks_total")
  blocksDone  Int      @default(0) @map("blocks_done")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Ingen Prisma-relasjon til FtdDocument — bruker rå SQL
  // FK constraint finnes i SQL: document_id → ftd_documents(id) ON DELETE CASCADE

  @@unique([documentId, targetLang])
  @@index([status])
  @@map("ftd_translation_jobs")
}

// Translation memory — cache for allerede oversatte tekster
model TranslationCache {
  id           String   @id @default(cuid())
  contentHash  String   @map("content_hash")  // SHA-256 av kildetekst
  sourceLang   String   @map("source_lang")
  targetLang   String   @map("target_lang")
  sourceText   String   @map("source_text")
  targetText   String   @map("target_text")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([contentHash, sourceLang, targetLang])
  @@map("translation_cache")
}

model FtdDocumentPage {
  id         String @id @default(cuid())
  documentId String @map("document_id")
  pageNumber Int    @map("page_number")
  postnr     String

  document FtdDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber])
  @@index([postnr])
  @@map("ftd_document_pages")
}

model FtdSpecPost {
