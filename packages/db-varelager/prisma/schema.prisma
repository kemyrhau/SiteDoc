// Vareforbruk-modul — Steg 4b
// Isolert datalag: eget postgres-schema "varelager", egen Prisma-klient.
// Samme PostgreSQL-instans som packages/db, ingen FK-relasjoner på tvers.
// Cross-package-FK håndteres som svake String-felt uten Prisma @relation
// (samme mønster som db-timer + db-maskin).

generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/varelager-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["varelager"]
}

// ==========================================================================
//  VareKategori — firma-definert kategori (Beslutning 8, 2026-05-06)
//  kontonummer forbereder regnskapseksport (ProAdm/Tripletax)
// ==========================================================================

model VareKategori {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id") // svak FK → organizations.id (kjernen)
  navn           String
  kontonummer    String? // for regnskapseksport
  aktiv          Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  varer Vare[]

  @@unique([organizationId, navn])
  @@index([organizationId, aktiv])
  @@map("vare_kategorier")
  @@schema("varelager")
}

// ==========================================================================
//  Vare — firma-katalog over forbruksvarer
//  Utleie-utstyr (per time/døgn) registreres som Equipment, ikke Vare
//  (Beslutning 3 i steg-4b-plan.md)
// ==========================================================================

model Vare {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id") // svak FK → organizations.id
  navn           String
  varenummer     String?
  enhet          String // "m" | "m2" | "m3" | "kg" | "kilo" | "tonn" | "stk" | "sekk" | "meter" | "liter" | "doegn" | "timer" | (fritekst)
  pris           Decimal? @db.Decimal(12, 2) // utsalgspris til kunde
  internkostnad  Decimal? @db.Decimal(12, 2) // innkjøpspris
  kategoriId     String?  @map("kategori_id")
  aktiv          Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  kategori    VareKategori? @relation(fields: [kategoriId], references: [id], onDelete: Restrict)
  vareforbruk Vareforbruk[]

  @@unique([organizationId, navn, enhet])
  @@index([organizationId, aktiv])
  @@index([kategoriId])
  @@map("varer")
  @@schema("varelager")
}

// ==========================================================================
//  Vareforbruk — prosjekt-transaksjon (én rad per registrert forbruk)
//  attestertSnapshot låser pris/navn/enhet ved attestering (A.7-mønster)
// ==========================================================================

model Vareforbruk {
  id                   String   @id @default(uuid())
  dato                 DateTime @db.Date
  projectId            String   @map("project_id") // svak FK → projects.id
  byggeplassId         String?  @map("byggeplass_id") // svak FK; NULL = hele prosjektet
  externalCostObjectId String?  @map("external_cost_object_id") // svak FK → external_cost_objects
  vareId               String   @map("vare_id")
  antall               Decimal  @db.Decimal(12, 2)
  registrertAvUserId   String   @map("registrert_av_user_id") // svak FK; ingen @relation (A.3-mønster)
  kommentar            String?
  dagsseddelId         String?  @map("dagsseddel_id") // svak FK → daily_sheets (db-timer)

  // Snapshot ved attestering (A.7) — {prisSnapshot, internkostnadSnapshot, varenavnSnapshot, enhetSnapshot, attestertVed}
  attestertSnapshot Json? @map("attestert_snapshot")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  vare Vare @relation(fields: [vareId], references: [id], onDelete: Restrict)

  @@index([projectId, dato])
  @@index([dagsseddelId])
  @@index([externalCostObjectId])
  @@index([vareId])
  @@map("vareforbruk")
  @@schema("varelager")
}
