# SmartDok API — engangs-migrering A.Markussen → SiteDoc
# Kopier denne til .env.local og fyll inn faktiske verdier.
# .env.local er gitignored og skal ALDRI commites.

# API-nøkkel fra SmartDok (Firmainnstillinger → Integrasjoner → API)
SMARTDOK_API_KEY=

# Base-URL for API (oppdateres når vi finner riktig endepunkt)
SMARTDOK_API_BASE=https://api.smartdok.com

# Firma-ID i SmartDok (om kreves som parameter)
SMARTDOK_COMPANY_ID=
